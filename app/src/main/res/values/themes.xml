<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AlFisal" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="android:statusBarColor">@color/primary</item>
        <item name="android:windowBackground">@color/white</item>
    </style>

    <style name="Theme.AlFisal.NoActionBar" parent="Theme.AlFisal">
        <item name="android:windowFullscreen">false</item>
        <item name="android:statusBarColor">@color/primary</item>
    </style>

    <style name="Theme.AlFisal.Splash" parent="Theme.AlFisal">
        <item name="android:windowBackground">@color/splash_bg</item>
        <item name="android:statusBarColor">@color/splash_bg</item>
        <item name="android:navigationBarColor">@color/splash_bg</item>
    </style>
</resources>
